#!/bin/sh
# Pre-commit hook: run gofmt and go vet before allowing commit.
# If any check fails, the commit is blocked.

set -e

echo "[pre-commit] Running gofmt..."
UNFORMATTED=$(gofmt -l .)
if [ -n "$UNFORMATTED" ]; then
  echo "[ERROR] The following files are not gofmt'd:"
  echo "$UNFORMATTED"
  echo ""
  echo "Fix with: gofmt -w ."
  exit 1
fi

echo "[pre-commit] Running go vet..."
go vet ./...
if [ $? -ne 0 ]; then
  echo "[ERROR] go vet reported issues. Fix them before committing."
  exit 1
fi

echo "[pre-commit] Running go test -short..."
go test -short ./...
if [ $? -ne 0 ]; then
  echo "[ERROR] go test -short failed. Fix failing tests before committing."
  exit 1
fi

echo "[pre-commit] All checks passed."
